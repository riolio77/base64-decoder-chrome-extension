{
  "manifest_version": 3,
  "name": "Base64 Decoder",
  "version": "1.2.0",
  "description": "텍스트를 선택하면 Base64 디코딩 버튼이 나타납니다.",
  "permissions": [
    "clipboardWrite"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Base64 Decoder"
  }
}